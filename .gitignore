# Android .gitignore
# Built application files
*.apk
*.ap_
# Files for the ART/Dalvik VM
*.dex
# Java class files
*.class
# Generated files
bin/
gen/
# Gradle files
.gradle/
build/
# Local configuration file (sdk path, etc.)
local.properties
# Proguard folder generated by Eclipse
proguard/
# Log files
*.log
# Android Studio specific files
.idea/
*.iml
# NDK
obj/
# Keystore files
*.jks
# Misc
*.orig
# Gradle Wrapper
gradle/wrapper/gradle-wrapper.properties
# End of .gitignore
