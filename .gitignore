# Android .gitignore
# Built application files
*.apk
*.ap_
# Files for the ART/Dalvik VM
*.dex
# Java class files
*.class
# Generated files
bin/
gen/
# Gradle files
.gradle/
build/
# Local configuration file (sdk path, etc.)
local.properties
# Proguard folder generated by Eclipse
proguard/
# Log files
*.log
# Android Studio specific files
.idea/
*.iml
# NDK
obj/
# Keystore files
*.jks
# Misc
*.orig
# Gradle Wrapper — do NOT ignore these, they are required for builds
# gradle/wrapper/gradle-wrapper.properties  <- intentionally not ignored
# End of .gitignore
