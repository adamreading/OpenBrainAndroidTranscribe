<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OpenBrain Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Supabase URL" />
        <EditText
            android:id="@+id/supabaseUrlEt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://your-project.supabase.co" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Supabase API Key"
            android:layout_marginTop="8dp" />
        <EditText
            android:id="@+id/supabaseKeyEt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="anon-key"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/testConnectionBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Connection"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wake Word Settings"
            android:textStyle="bold" />
        <EditText
            android:id="@+id/wakeWordEt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Hey Adam" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Whisper Model"
            android:layout_marginTop="8dp" />
        <Spinner
            android:id="@+id/whisperModelSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LLM Model"
            android:layout_marginTop="8dp" />
        <Spinner
            android:id="@+id/llmModelSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>
</ScrollView>
